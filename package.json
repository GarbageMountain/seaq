{
  "name": "seaq-monorepo",
  "private": true,
  "version": "2.0.0-rc.1",
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "yarn workspaces foreach -A run build",
    "test": "yarn workspaces foreach -A run test",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "ts-check": "tsc --build --incremental",
    "dev": "yarn workspace seaq build && (yarn workspace seaq dev & yarn workspace @seaq/examples dev & wait)",
    "clean": "rm -rf .tsc-out packages/*/dist",
    "bench:save": "yarn workspace seaq bench:save"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@vitest/coverage-v8": "^4.0.18",
    "seaq": "1.1.5",
    "typescript": "^5.9.3"
  }
}
