{
  "name": "@seaq/test-data",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./contacts-1k.json": "./data/contacts-1k.json",
    "./contacts-10k.json": "./data/contacts-10k.json",
    "./cities.json": "./data/cities.json",
    "./books.json": "./data/books.json"
  },
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsup",
    "generate": "node scripts/generate-contacts.mjs"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
